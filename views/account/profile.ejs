<form action="/account/profile" method="POST">

   <input 
      type="text"
      name="firstname"
      value="<%= user.firstname %>"
   >

   <input 
      type="text"
      name="lastname"
      value="<%= user.lastname %>"
   >

   <input 
      type="email"
      name="email"
      value="<%= user.email %>"
   >

   <button type="submit">
      Enregistrer
   </button>

</form>