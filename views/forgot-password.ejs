<!DOCTYPE html>
<html lang="fr">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">

   <title>Mot de passe oublié</title>

   <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="global-nav nav-black">

   <div class="nav-content">

      <span class="apple-logo">
         <a href="/"></a>
      </span>

      <ul>
         <li><a href="/fr/iphone/">iPhone</a></li>
      </ul>

   </div>

</nav>

<div class="forgot-page">

   <div class="forgot-card">

      <h1>Réinitialiser le mot de passe</h1>

      <p class="forgot-subtitle">
         Entrez votre adresse e-mail pour recevoir un lien sécurisé.
      </p>

      <form action="/forgot-password" method="POST">

         <div class="forgot-input-group">

            <input
               type="email"
               name="email"
               placeholder="Adresse e-mail"
               required
            >

         </div>

         <button type="submit" class="forgot-btn">
            Envoyer le lien
         </button>

      </form>

   </div>

</div>

</body>
</html>