<div class="cart-container">
  <h1>Mon Panier</h1>

  <% if (!cart || cart.length === 0) { %>
    <p class="empty">Votre panier est vide</p>
  <% } else { %>

    <div class="cart-list">
      <% let total = 0; %>

      <% cart.forEach(item => { %>

        <div class="cart-item" id="item-<%= item._id %>"> <!-- 🔥 AJOUT ID -->

          <img src="<%= item.image %>" class="cart-img">

          <div class="cart-details">
            <h3><%= item.name %></h3>
            <p class="price"><%= item.price %>$</p>
          </div>

          <div class="cart-qty">
            <button onclick="updateCart('/cart/increase/<%= item._id %>', '<%= item._id %>')">+</button>

            <!-- 🔥 AJOUT QUANTITÉ -->
            <span id="qty-<%= item._id %>"><%= item.quantity %></span>

            <button onclick="updateCart('/cart/decrease/<%= item._id %>','<%= item._id %>')">−</button>

            <button onclick="confirmDelete('/cart/remove/<%= item._id %>','<%= item._id %>')">
              Supprimer
            </button>
          </div>

        </div>

        <% total += item.price * item.quantity; %>

      <% }) %>
    </div>

    <div class="cart-total" id="cart-total">
      Total: <%= total %>$
    </div>

 <button type="button" class="checkout-btn" onclick="payWithStripe()">
  Passer la commande
</button>

  <% } %>
</div>

<!-- 🔥 INJECTION DU SCRIPT DE PAIEMENT DIRECTEMENT DANS LA PAGE PANIER -->
<script>
async function payWithStripe() {
  try {
    console.log("🚀 Clic sur le bouton de paiement détecté directement depuis le EJS !");
    
    const checkoutBtn = document.querySelector('.checkout-btn');
    if (checkoutBtn) {
      checkoutBtn.innerText = "Chargement...";
      checkoutBtn.disabled = true;
    }

    // Appel à votre route de paiement Express
    // Si votre route de création de session Stripe s'appelle autrement (ex: /create-checkout-session), modifiez l'adresse ici :
    const res = await fetch('/checkout-stripe', {
      method: 'GET', // GET car votre fonction 'checkoutStripe' récupère l'utilisateur depuis req.session
      headers: {
        'Content-Type': 'application/json'
      },
      credentials: 'include' // Obligatoire pour transmettre la session utilisateur sur Render
    });

    // Sécurité : Si votre route backend attend du POST au lieu du GET, on gère automatiquement la bascule
    if (res.status === 404 || res.status === 405) {
      console.log("⚠️ Route GET non configurée, bascule automatique sur POST...");
      const retryRes = await fetch('/checkout-stripe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include'
      });
      const retryData = await retryRes.json();
      handleStripeRedirect(retryData, checkoutBtn);
      return;
    }

    const data = await res.json();
    handleStripeRedirect(data, checkoutBtn);

  } catch (err) {
    console.error("❌ Erreur lors du clic de paiement :", err);
    alert("Une erreur de communication avec le serveur est survenue.");
    resetCheckoutButton();
  }
}

function handleStripeRedirect(data, button) {
  console.log("💳 Réponse de votre serveur backend :", data);
  if (data.status === 'success' && data.url) {
    window.location.href = data.url; // 🚀 Redirection instantanée vers Stripe
  } else {
    alert(data.message || 'Erreur lors de la création de la session de paiement.');
    resetCheckoutButton(button);
  }
}

function resetCheckoutButton(button) {
  if (button) {
    button.innerText = "Passer la commande";
    button.disabled = false;
  }
}
</script>
