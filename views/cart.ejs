<div class="cart-container">
  <h1>Mon Panier</h1>

  <% if (!cart || cart.length === 0) { %>
    <p class="empty">Votre panier est vide</p>
  <% } else { %>

    <div class="cart-list">
      <% let total = 0; %>

      <% cart.forEach(item => { %>

        <div class="cart-item" id="item-<%= item._id %>"> <!-- 🔥 AJOUT ID -->

          <img src="<%= item.image %>" class="cart-img">

          <div class="cart-details">
            <h3><%= item.name %></h3>
            <p class="price"><%= item.price %>$</p>
          </div>

          <div class="cart-qty">
            <button onclick="updateCart('/cart/increase/<%= item._id %>', '<%= item._id %>')">+</button>

            <!-- 🔥 AJOUT QUANTITÉ -->
            <span id="qty-<%= item._id %>"><%= item.quantity %></span>

            <button onclick="updateCart('/cart/decrease/<%= item._id %>','<%= item._id %>')">−</button>

            <button onclick="confirmDelete('/cart/remove/<%= item._id %>','<%= item._id %>')">
              Supprimer
            </button>
          </div>

        </div>

        <% total += item.price * item.quantity; %>

      <% }) %>
    </div>

    <div class="cart-total" id="cart-total">
      Total: <%= total %>$
    </div>

 <button type="button" class="checkout-btn" onclick="payWithStripe()">
  Passer la commande
</button>

  <% } %>
</div>

<script>
async function payWithStripe() {
  try {
    console.log("🚀 Clic sur le bouton de paiement.");
    
    const checkoutBtn = document.querySelector('.checkout-btn');
    if (checkoutBtn) {
      checkoutBtn.innerText = "Chargement...";
      checkoutBtn.disabled = true;
    }

    // ✅ CORRECTION : Utilise l'URL exacte définie dans votre routeur backend
    const res = await fetch('/create-checkout-session', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      credentials: 'include' // Indispensable pour transmettre la session utilisateur sur Render
    });

    const data = await res.json();
    console.log("💳 Réponse du serveur :", data);

    if (data.status === 'success' && data.url) {
      window.location.href = data.url; // 🚀 Redirection instantanée vers Stripe !
    } else {
      alert(data.message || 'Erreur lors de la création de la session de paiement.');
      resetButton(checkoutBtn);
    }

  } catch (err) {
    console.error("❌ Erreur lors du clic :", err);
    alert("Une erreur de communication est survenue.");
    resetButton(document.querySelector('.checkout-btn'));
  }
}

function resetButton(button) {
  if (button) {
    button.innerText = "Passer la commande";
    button.disabled = false;
  }
}
</script>
